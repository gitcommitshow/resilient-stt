# Copy to .env and fill in values (optional for many runs):
#   cp .env.example .env
#
# On startup, `orchestrator.main` loads `.env` automatically (python-dotenv).
# Variables already set in your shell are not overwritten.

# --- Shortest full pipeline (OpenAI ASR + repair) ---
# Set only this key when no local ASR (vLLM :8001 / qwen-asr :8002) is running:
# OPENAI_API_KEY=sk-...
#
# --- OpenRouter ASR + repair (alternative hosted path) ---
# OPENROUTER_API_KEY=sk-or-...
# Auto-detected when no local ASR; same rules as OpenAI (no --model, no ASR_BASE_URL).
# Or set explicitly:
# ASR_BASE_URL=https://openrouter.ai/api/v1
# ASR_API_KEY=sk-or-...
#
#   uv run python -m orchestrator.main --audio path/to/audio.mp3 --output data/output/run
#
# Local ASR is preferred when available. Hosted ASR auto-detection requires:
# no --model, no ASR_BASE_URL/ASR_ENDPOINT, and no reachable local worker.
# OPENROUTER_API_KEY is tried before OPENAI_API_KEY when both are set.

# --- ASR (external OpenAI-compatible microservice) ---
# Optional overrides when not using OPENAI_API_KEY auto-detection.
# If unset, the orchestrator probes OpenAI (when OPENAI_API_KEY is set), then vLLM
# at http://127.0.0.1:8001/v1, then may auto-start local qwen-asr at :8002.
# ASR_BASE_URL=
# ASR_ENDPOINT=
ASR_API_KEY=

# --- LLM transcript repair (optional overrides; auto-filled from OPENAI_API_KEY) ---
REPAIR_BASE_URL=
REPAIR_MODEL=
REPAIR_API_KEY=

# --- pyannote diarization (optional; skip with --skip-diarization) ---
# Used only to download gated model weights from Hugging Face — not for ASR.
# Accept terms at https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=

# --- Offline diarization (alternative to HF_TOKEN after one-time clone) ---
# Pass the same path on the CLI: --diarization-model-path /path/to/clone
# DIARIZATION_MODEL_PATH=

# --- Privacy / telemetry (optional opt-in) ---
# The orchestrator disables dependency telemetry by default on startup.
# Uncomment to re-enable pyannote usage metrics or Hugging Face Hub telemetry:
# PYANNOTE_METRICS_ENABLED=1
# HF_HUB_DISABLE_TELEMETRY=0
