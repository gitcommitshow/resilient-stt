# Copy to .env and fill in values (optional for many runs):
#   cp .env.example .env
#
# On startup, `orchestrator.main` loads `.env` automatically (python-dotenv).
# Variables already set in your shell are not overwritten.

# --- ASR (external OpenAI-compatible microservice) ---
# Optional: set when using a remote/hosted ASR service.
# If unset, the orchestrator probes vLLM at http://127.0.0.1:8001/v1, then may
# auto-start local qwen-asr (CPU/MPS) at http://127.0.0.1:8002/v1.
# ASR_BASE_URL=
# ASR_ENDPOINT=
ASR_API_KEY=

# --- LLM transcript repair (optional; only when --repair true) ---
REPAIR_BASE_URL=https://api.openai.com/v1
REPAIR_MODEL=gpt-4o-mini
REPAIR_API_KEY=

# --- pyannote diarization (optional; skip with --skip-diarization) ---
# Used only to download gated model weights from Hugging Face — not for ASR.
# Accept terms at https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=

# --- Offline diarization (alternative to HF_TOKEN after one-time clone) ---
# Pass the same path on the CLI: --diarization-model-path /path/to/clone
# DIARIZATION_MODEL_PATH=

# --- Privacy / telemetry (optional opt-in) ---
# The orchestrator disables dependency telemetry by default on startup.
# Uncomment to re-enable pyannote usage metrics or Hugging Face Hub telemetry:
# PYANNOTE_METRICS_ENABLED=1
# HF_HUB_DISABLE_TELEMETRY=0
